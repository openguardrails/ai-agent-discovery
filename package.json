{
  "name": "ai-agent-discovery",
  "version": "1.0.0",
  "description": "Enterprise tool for discovering AI Agents running within an organization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aad": "./bin/aad.js",
    "ai-agent-discovery": "./bin/aad.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
