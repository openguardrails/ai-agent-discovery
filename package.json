  "repository": {
    "type": "git",
    "url": "https://github.com/OpenGuardrails/ai-agent-discovery.git"
  },
  "homepage": "https://openguardrails.io/ai-agent-discovery",
  "bugs": {
    "url": "https://github.com/OpenGuardrails/ai-agent-discovery/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "js-yaml": "^4.1.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  }
